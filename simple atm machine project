def atm_machine():
    # Setup initial user data
    correct_pin = "1234"
    balance = 1000.00
    is_logged_in = False

    print("=== Welcome to the TechBank ATM ===")

    # 1. PIN Verification Loop
    attempts = 3
    while attempts > 0:
        entered_pin = input("Please enter your 4-digit PIN: ")
        if entered_pin == correct_pin:
            is_logged_in = True
            print("\nPIN accepted! Welcome to your account.")
            break
        else:
            attempts -= 1
            print(f"Incorrect PIN. Attempts remaining: {attempts}")
    
    if not is_logged_in:
        print("Too many incorrect attempts. Card blocked. Goodbye!")
        return

    # 2. Main ATM Menu Loop
    while True:
        print("\n" + "="*25)
        print("        ATM MENU        ")
        print("="*25)
        print("1. Check Balance")
        print("2. Deposit Money")
        print("3. Withdraw Money")
        print("4. Exit")
        
        choice = input("\nChoose an option (1-4): ")

        # 3. Conditionals for Menu Navigation
        if choice == "1":
            print(f"\nYour current balance is: ${balance:,.2f}")
            
        elif choice == "2":
            deposit_amount = float(input("\nEnter amount to deposit: $"))
            if deposit_amount > 0:
                balance += deposit_amount
                print(f"${deposit_amount:,.2f} successfully deposited.")
                print(f"New balance: ${balance:,.2f}")
            else:
                print("Invalid amount. Please enter a positive value.")
                
        elif choice == "3":
            withdraw_amount = float(input("\nEnter amount to withdraw: $"))
            if withdraw_amount > balance:
                print("\nTransaction Denied: Insufficient funds.")
            elif withdraw_amount <= 0:
                print("\nInvalid amount. Please enter a positive value.")
            else:
                balance -= withdraw_amount
                print(f"\nPlease take your cash: ${withdraw_amount:,.2f}")
                print(f"Remaining balance: ${balance:,.2f}")
                
        elif choice == "4":
            print("\nThank you for using TechBank ATM. Have a nice day.")
            break

        else:
            print("\nPlease choose a valid option from the menu.")


atm_machine()
